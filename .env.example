# Nest Agent Hypervisor - Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# LLM PROVIDERS
# ==============================================================================
# Get API keys from respective provider websites:
# - Anthropic: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/api-keys
# - OpenRouter: https://openrouter.ai/keys

# Anthropic (Claude 3 / Claude 3.5)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT-4o / GPT-4o Mini)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (all supported models)
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# z.ai (https://z.ai)
# ZAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mistral AI
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Together.ai
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# RUNTIME CONFIGURATION
# ==============================================================================

# Default LLM provider to use when not specified in hand manifest
# Valid values: anthropic, openai, openrouter
NEST_DEFAULT_PROVIDER=anthropic

# Default model to use when not specified
# NEST_DEFAULT_MODEL=claude-3-5-sonnet-20240620

# Maximum concurrent agents running simultaneously
NEST_MAX_CONCURRENT_AGENTS=4

# ==============================================================================
# SECURITY
# ==============================================================================

# Require user confirmation for all permission requests
# Set to false to auto-approve requests for testing
NEST_REQUIRE_PERMISSION_CONFIRMATION=true

# Auto-deny permissions after timeout (seconds)
NEST_PERMISSION_TIMEOUT=300

# ==============================================================================
# AUDIT LOG
# ==============================================================================

# Enable immutable audit log
NEST_AUDIT_LOG_ENABLED=true

# Audit log path (absolute or relative)
NEST_AUDIT_LOG_PATH=./var/audit.log

# Enable Merkle chain hashing for tamper protection
NEST_AUDIT_MERKLE_CHAIN=true

# ==============================================================================
# SANDBOX
# ==============================================================================

# Sandbox root directory for agent filesystems
NEST_SANDBOX_ROOT=./var/sandbox

# Default memory limit per agent (MB)
NEST_DEFAULT_MEMORY_LIMIT=512

# Default CPU limit per agent (percent)
NEST_DEFAULT_CPU_LIMIT=50

# ==============================================================================
# MCP SERVERS
# ==============================================================================

# Enable built-in MCP servers
NEST_MCP_ENABLE_FILESYSTEM=true
NEST_MCP_ENABLE_SHELL=true
NEST_MCP_ENABLE_WEB=true
NEST_MCP_ENABLE_MEMORY=true

# ==============================================================================
# LOGGING
# ==============================================================================

# Log level: trace, debug, info, warn, error
NEST_LOG_LEVEL=info

# Enable JSON structured logging
NEST_LOG_JSON=false
